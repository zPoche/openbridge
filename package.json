{
  "name": "openbridge",
  "version": "0.1.0",
  "description": "Import Gantt project plans into OpenProject",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder",
    "test": "node tests/run.js"
  },
  "build": {
    "appId": "com.openbridge.app",
    "productName": "openbridge",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "xlsx": "^0.18.5",
    "csv-parse": "^5.5.0"
  },
  "devDependencies": {
    "electron": "41.2.1",
    "electron-builder": "26.8.1"
  }
}
